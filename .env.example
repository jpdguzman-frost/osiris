# Anthropic API (required for analysis phase)
ANTHROPIC_API_KEY=sk-ant-...

# MongoDB (required for data storage phase)
MONGODB_URI=mongodb://localhost:27017

# Google Custom Search API (for image search collection)
# Create at: https://programmablesearchengine.google.com/
# Get API key at: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional: Budget cap in USD (default: 200)
BUDGET_CAP=200
